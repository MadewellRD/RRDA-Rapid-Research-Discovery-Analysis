# RDA Configuration

# Database
DATABASE_URL=postgresql://rda_user:rda_password@localhost:5432/rda_intelligence

# OpenAI
OPENAI_API_KEY=your-openai-key-here

# GitHub (Multi-account)
GITHUB_TOKEN_1=your-github-token-rda-1
GITHUB_TOKEN_2=your-github-token-rda-2
GITHUB_USERNAME_1=forge-rda-1
GITHUB_USERNAME_2=forge-rda-2

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=forge-rda-1@madewellrd.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=rda@madewellrd.com

# Slack (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# RDA API
RDA_API_PORT=4000
RDA_API_KEY=your-secret-api-key

# FORGE Integration (optional)
FORGE_API_URL=http://localhost:3000/api
FORGE_API_KEY=forge-api-key

# Scanning Configuration
SCAN_GITHUB_TRENDING=true
SCAN_HACKERNEWS=true
SCAN_REDDIT=true
SCAN_ARXIV=true

# Storage
CLONES_DIRECTORY=/opt/PROMETHEUS/rda/clones
MAX_CLONES=50
CLONE_RETENTION_DAYS=7

# Scheduling
ENABLE_SCHEDULER=true
ENABLE_AUTO_ANALYSIS=true
ENABLE_AUTO_TICKETS=false

# Debug
NODE_ENV=development
LOG_LEVEL=info
