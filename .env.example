# RRDA Configuration

# Database
DATABASE_URL=postgresql://rda_user:rda_password@localhost:5432/rda_intelligence

# HTTP API
RDA_API_PORT=4000
CORS_ORIGIN=http://localhost:4173

# LLM Provider: "openai" or "bitnet"
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-key-here

# Local OpenAI-compatible model server
BITNET_BASE_URL=http://localhost:8080/v1
BITNET_MODEL=bitnet-b1.58-2B-4T

# GitHub (optional, at least one token recommended)
GITHUB_TOKEN_1=your-github-token-1
GITHUB_TOKEN_2=
GITHUB_USERNAME_1=rrda-bot-1
GITHUB_USERNAME_2=

# Email notifications (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=team@example.com

# Slack (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Scanning Configuration
SCAN_GITHUB_TRENDING=true
SCAN_HACKERNEWS=true
SCAN_REDDIT=true
SCAN_ARXIV=true

# Deep analysis / storage
CLONES_DIRECTORY=./clones
MAX_CLONE_SIZE_MB=500
CLONE_RETENTION_HOURS=4

# Scheduling
ENABLE_SCHEDULER=true
ENABLE_AUTO_ANALYSIS=true

# Debug
NODE_ENV=development
LOG_LEVEL=info
